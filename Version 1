<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <?!= include('Styles'); ?>
</head>
<body>
  <div class="card">
    <h2>Company Portal Login</h2>
    <input id="email" placeholder="Enter company email">
    <button onclick="sendOtp()">Send OTP</button>

    <input id="otp" placeholder="Enter OTP">
    <button onclick="verifyOtp()">Login</button>

    <div id="msg"></div>
  </div>

  <?!= include('Scripts'); ?>
  <script>
    function sendOtp() {
      const email = document.getElementById('email').value;
      google.script.run.withSuccessHandler(res => {
        document.getElementById('msg').innerText = res.ok ? 'OTP sent' : res.message;
      }).sendOtp(email);
    }

    function verifyOtp() {
      const email = document.getElementById('email').value;
      const otp = document.getElementById('otp').value;
      google.script.run.withSuccessHandler(res => {
        if (res.ok) {
          localStorage.setItem('sessionToken', res.token);
          window.location.href = '<?= appUrl ?>?page=home';
        } else {
          document.getElementById('msg').innerText = res.message;
        }
      }).verifyOtp(email, otp);
    }
  </script>
</body>
</html>
