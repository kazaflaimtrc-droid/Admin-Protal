const SHEET_USERS = 'Users';
const SHEET_LEAVE = 'Leave_Balance';
const SHEET_NOTICES = 'Notices';
const SHEET_LOGS = 'Login_Logs';

function doGet(e) {
  const page = (e && e.parameter && e.parameter.page) || 'login';
  const allowed = ['login', 'home', 'leave', 'admin_notice', 'admin_leave'];

  const view = allowed.includes(page) ? page : 'login';
  const template = HtmlService.createTemplateFromFile(capitalizePage(view));
  template.appUrl = ScriptApp.getService().getUrl();
  return template.evaluate().setTitle('Company Portal');
}

function include(filename) {
  return HtmlService.createHtmlOutputFromFile(filename).getContent();
}

function capitalizePage(page) {
  const map = {
    login: 'Login',
    home: 'Home',
    leave: 'MyLeave',
    admin_notice: 'AdminNotice',
    admin_leave: 'AdminLeave'
  };
  return map[page] || 'Login';
}
